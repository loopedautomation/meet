# Production reverse proxy. Caddy auto-provisions TLS for both hosts.
# Domains come from .env (MEET_DOMAIN / LK_DOMAIN); defaults match looped's
# deployment — override them for your own self-hosted instance.

{$MEET_DOMAIN:meet.lpd.sh} {
	reverse_proxy web:3000
}

{$LK_DOMAIN:lk.lpd.sh} {
	# LiveKit signaling (WebSocket) + HTTP APIs. Media flows over UDP/TCP
	# directly to the livekit service, not through Caddy.
	reverse_proxy livekit:7880
}

# Guessable alias on the marketing domain.
{$MEET_ALIAS_DOMAIN:meet.looped.sh} {
	redir https://{$MEET_DOMAIN:meet.lpd.sh}{uri} permanent
}
